@startuml
skinparam backgroundColor #FFFFFF
skinparam shadowing false
skinparam dpi 180
skinparam defaultFontName Microsoft YaHei
skinparam linetype ortho
skinparam packageStyle rectangle
skinparam componentStyle rectangle
skinparam roundCorner 12
skinparam ArrowColor #8B8B8B
skinparam ArrowThickness 1.2

skinparam rectangle {
  BorderColor #FFFFFF
  FontColor #2F2F2F
}

skinparam rectangle<<layer>> {
  BackgroundColor #F4F5F7
  BorderColor #E5E7EB
  FontStyle bold
  FontSize 16
}

skinparam rectangle<<user>> {
  BackgroundColor #FFE0D6
  BorderColor #FFE0D6
}

skinparam rectangle<<front>> {
  BackgroundColor #DCEEFF
  BorderColor #DCEEFF
}

skinparam rectangle<<api>> {
  BackgroundColor #F8E0D5
  BorderColor #F8E0D5
}

skinparam rectangle<<service>> {
  BackgroundColor #E8D9FF
  BorderColor #E8D9FF
}

skinparam rectangle<<support>> {
  BackgroundColor #EEEEEE
  BorderColor #EEEEEE
}

skinparam rectangle<<data>> {
  BackgroundColor #DEF3E4
  BorderColor #DEF3E4
}

skinparam rectangle<<infra>> {
  BackgroundColor #D7ECFF
  BorderColor #D7ECFF
}

top to bottom direction
title 双链笔记系统分层架构图（方案二）

rectangle "用户访问层" as L1 <<layer>> {
  together {
    actor "用户" as U
    rectangle "浏览器访问" as U1 <<user>>
  }
}

rectangle "表示与交互层" as L2 <<layer>> {
  together {
    rectangle "Vue 3 单页应用" as F1 <<front>>
    rectangle "知识库工作台" as F2 <<front>>
    rectangle "Vditor 笔记编辑器" as F3 <<front>>
    rectangle "知识图谱可视化" as F4 <<front>>
    rectangle "标签 / 模板 / 设置界面" as F5 <<front>>
    rectangle "Ajax / Fetch 异步通信" as F6 <<front>>
  }
}

F1 -[hidden]right-> F2
F2 -[hidden]right-> F3
F3 -[hidden]right-> F4
F4 -[hidden]right-> F5
F5 -[hidden]right-> F6

rectangle "接口与认证层" as L3 <<layer>> {
  together {
    rectangle "RESTful API" as A1 <<api>>
    rectangle "JWT 身份认证" as A2 <<api>>
    rectangle "Spring Security" as A3 <<api>>
    rectangle "CORS / 拦截器 / 异常处理" as A4 <<api>>
  }
}

A1 -[hidden]right-> A2
A2 -[hidden]right-> A3
A3 -[hidden]right-> A4

rectangle "业务服务层（Spring Boot）" as L4 <<layer>> {
  together {
    rectangle "用户服务\n登录、注册、个人信息、头像" as S1 <<service>>
    rectangle "知识库服务\n知识库、文件夹、目录树" as S2 <<service>>
    rectangle "笔记服务\n创建、编辑、自动保存、双链" as S3 <<service>>
    rectangle "扩展服务\n标签、模板、附件、图谱" as S4 <<service>>
  }
}

S1 -[hidden]right-> S2
S2 -[hidden]right-> S3
S3 -[hidden]right-> S4

rectangle "数据处理层" as L5 <<layer>> {
  together {
    rectangle "Controller" as D1 <<support>>
    rectangle "Service" as D2 <<support>>
    rectangle "Mapper / MyBatis-Plus" as D3 <<support>>
    rectangle "Entity / DTO / VO" as D4 <<support>>
    rectangle "application.yaml" as D5 <<support>>
  }
}

D1 -[hidden]right-> D2
D2 -[hidden]right-> D3
D3 -[hidden]right-> D4
D4 -[hidden]right-> D5

rectangle "数据与资源层" as L6 <<layer>> {
  together {
    rectangle "MySQL 数据库\n用户、知识库、文件夹、笔记、标签、模板、链接" as R1 <<data>>
    rectangle "文件资源存储\nuploads/avatars\nuploads/attachments" as R2 <<data>>
  }
}

R1 -[hidden]right-> R2

rectangle "技术支撑层" as L7 <<layer>> {
  together {
    rectangle "JDK 17" as I1 <<infra>>
    rectangle "Spring Boot 3" as I2 <<infra>>
    rectangle "Vue 3 + Vite" as I3 <<infra>>
    rectangle "MyBatis-Plus" as I4 <<infra>>
    rectangle "MySQL" as I5 <<infra>>
    rectangle "Vditor" as I6 <<infra>>
  }
}

I1 -[hidden]right-> I2
I2 -[hidden]right-> I3
I3 -[hidden]right-> I4
I4 -[hidden]right-> I5
I5 -[hidden]right-> I6

U --> U1
U1 --> F1
F6 --> A1 : HTTP / JSON
A1 --> S1
A1 --> S2
A1 --> S3
A1 --> S4
S1 --> D2
S2 --> D2
S3 --> D2
S4 --> D2
D1 --> D2
D2 --> D3
D2 --> D4
D3 --> R1
S4 --> R2
L7 -up-> R1
L7 -up-> R2
A2 ..> A1
A3 ..> A1
A4 ..> A1
D5 ..> D1
D5 ..> D2

@enduml
